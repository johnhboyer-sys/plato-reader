---
// No-flash theme setup. Runs in <head> before paint so the page renders in the
// correct theme immediately. Honours a saved choice, else defaults to light
// (the parchment reader) regardless of the OS appearance setting.
---
<script is:inline>
  (function () {
    try {
      var saved = localStorage.getItem('ne-theme');
      document.documentElement.dataset.theme = saved === 'dark' ? 'dark' : 'light';
    } catch (e) {
      /* localStorage unavailable: fall back to light (CSS default). */
    }
  })();
</script>
