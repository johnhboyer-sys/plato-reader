---
// The Greek Lexicon index at /lemma — a crawlable directory of every built lemma
// page, sorted alphabetically by transliteration. Doubles as the DefinedTermSet
// landing and an internal-link hub so the per-lemma pages get discovered.
import { readFileSync } from 'node:fs';
import ThemeInit from '../../components/ThemeInit.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import Pwa from '../../components/Pwa.astro';
import { jsonLdSafe } from '../../lib/jsonld';
import { greekFold } from '@shared/lib/search';
import '@shared/styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Read the popup manifest (lsjKey -> {slug, head, count}) for the full built set.
const manifest: Record<string, { slug: string; head: string; count: number }> = JSON.parse(
  readFileSync('public/data/lemmata.json', 'utf-8'),
);
// `fold` folds the polytonic head to Beta-Code letters (accent-stripped) so the
// client filter can match it against either Greek or Beta Code input with the
// same greekFold — see the inline script below.
const entries = Object.values(manifest)
  .map((e) => ({ ...e, fold: greekFold(e.head) }))
  .sort((a, b) => a.slug.localeCompare(b.slug));

const pageTitle = "Lexicon of Plato's Greek — Word Frequency & Concordance";
const metaDescription =
  `A growing lexicon of Plato's Greek vocabulary: ${entries.length} key terms with` +
  ` LSJ definitions, corpus-wide frequency counts, and every occurrence linked to the` +
  ` parallel Greek–English text with Stephanus citation.`;
const canonical = Astro.site ? new URL(`${base}/lemma/`, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL(`${base}/og-default.png`, Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: "Lexicon of Plato's Greek",
  description: metaDescription,
  ...(canonical ? { url: canonical } : {}),
  hasDefinedTerm: entries.slice(0, 100).map((e) => ({
    '@type': 'DefinedTerm', name: e.head, inLanguage: 'grc',
    ...(canonical ? { url: new URL(`${base}/lemma/${e.slug}/`, Astro.site!).href } : {}),
  })),
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeInit />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={metaDescription} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:site_name" content="The Plato Reader" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={metaDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <script type="application/ld+json" set:html={jsonLdSafe(jsonLd)} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon.png`} type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    .lxi-body { max-width: 900px; margin: 0 auto; padding: 2rem 1rem 5rem; font-family: var(--font-english); color: var(--text); }
    .lxi-h1 { font-size: 1.8rem; font-weight: 600; margin: 0 0 0.4rem; }
    .lxi-lede { color: var(--text-mid); line-height: 1.6; margin: 0 0 1.2rem; max-width: 60ch; }
    .lxi-filter { display: flex; align-items: center; gap: 0.7rem; margin: 0 0 1.4rem; position: sticky; top: 0; z-index: 5; background: var(--col-bg); padding: 0.5rem 0; }
    .lxi-filter input {
      flex: 1 1 auto; min-width: 0; font-family: var(--font-ui); font-size: 1rem;
      padding: 0.55rem 0.8rem; color: var(--text); background: var(--surface, var(--col-bg));
      border: 1px solid var(--border); border-radius: 8px;
    }
    .lxi-filter input:focus { outline: none; border-color: var(--accent); }
    .lxi-count { font-family: var(--font-ui); font-variant-numeric: tabular-nums; font-size: 0.82rem; color: var(--text-mid); white-space: nowrap; }
    .lxi-empty { color: var(--text-mid); font-size: 0.95rem; margin: 1rem 0; }
    .lxi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 13rem), 1fr)); gap: 0.4rem; list-style: none; padding: 0; margin: 0; }
    .lxi-grid a { display: flex; justify-content: space-between; gap: 0.6rem; align-items: baseline; text-decoration: none; color: var(--text); border: 1px solid var(--border); border-radius: 6px; padding: 0.5rem 0.7rem; }
    .lxi-grid a:hover { border-color: var(--accent); }
    .lxi-gk { font-family: var(--font-greek); font-size: 1.05rem; }
    .lxi-n { font-variant-numeric: tabular-nums; font-size: 0.78rem; color: var(--text-mid); }
  </style>
  <Pwa />
</head>
<body>
  <header class="simple-header">
    <div class="header-title">
      <a class="home-link" href={`${base}/`}>Plato</a>
      <span class="title-sep">›</span>
      <span class="header-static">Greek Lexicon</span>
    </div>
    <nav class="header-actions" aria-label="Navigation">
      <a href={`${base}/`} class="search-link">All works</a>
      <a href={`${base}/search`} class="search-link">Search</a>
      <ThemeToggle />
    </nav>
  </header>
  <main class="lxi-body">
    <h1 class="lxi-h1">Lexicon of Plato's Greek</h1>
    <p class="lxi-lede">
      {entries.length} key terms from Plato's vocabulary — each with its LSJ definition,
      how often it appears across the corpus, and every occurrence linked to the parallel
      Greek–English text. A concordance you can read.
    </p>
    <div class="lxi-filter">
      <input
        type="search"
        id="lxi-input"
        placeholder="Filter — type Greek (οὐσ) or Beta Code (ous)…"
        autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false"
        aria-label="Filter the lexicon by Greek or Beta Code"
      />
      <span class="lxi-count" id="lxi-count" aria-live="polite"></span>
    </div>
    <ul class="lxi-grid" id="lxi-grid">
      {entries.map((e) => (
        <li data-fold={e.fold}>
          <a href={`${base}/lemma/${e.slug}/`}>
            <span class="lxi-gk">{e.head}</span>
            <span class="lxi-n">{e.count.toLocaleString()}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="lxi-empty" id="lxi-empty" hidden>No entries match. Try the dictionary form (e.g. <span style="font-family:var(--font-greek)">οὐσία</span>, not an inflected form).</p>
  </main>

  <script>
    // Client filter: fold both the built-in `data-fold` (already Beta-folded from
    // the polytonic head at build) and the user's query with the SAME greekFold,
    // so typing polytonic Greek OR Beta Code both match. Prefix match, like a
    // dictionary lookup.
    const GREEK_BETA: Record<string, string> = {
      α:'a',β:'b',γ:'g',δ:'d',ε:'e',ζ:'z',η:'h',θ:'q',ι:'i',κ:'k',
      λ:'l',μ:'m',ν:'n',ξ:'c',ο:'o',π:'p',ρ:'r',σ:'s',ς:'s',τ:'t',
      υ:'u',φ:'f',χ:'x',ψ:'y',ω:'w',ϝ:'v',
    };
    const fold = (s: string) => {
      let out = '';
      for (const ch of s.normalize('NFD')) {
        const lower = ch.toLowerCase();
        if (GREEK_BETA[lower]) out += GREEK_BETA[lower];
        else if (lower >= 'a' && lower <= 'z') out += lower;
      }
      return out;
    };
    const input = document.getElementById('lxi-input') as HTMLInputElement | null;
    const grid = document.getElementById('lxi-grid');
    const countEl = document.getElementById('lxi-count');
    const emptyEl = document.getElementById('lxi-empty');
    if (input && grid) {
      const items = Array.from(grid.querySelectorAll<HTMLLIElement>('li'));
      const total = items.length;
      const apply = () => {
        const q = fold(input.value.trim());
        let shown = 0;
        for (const li of items) {
          const hit = !q || (li.dataset.fold ?? '').startsWith(q);
          li.hidden = !hit;
          if (hit) shown++;
        }
        if (countEl) countEl.textContent = q ? `${shown} of ${total}` : '';
        if (emptyEl) emptyEl.hidden = shown !== 0;
      };
      input.addEventListener('input', apply);
    }
  </script>
</body>
</html>
