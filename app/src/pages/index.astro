---
import { AUTHENTICITY_LABEL, SHELVES, START_HERE, getWork, workLanding, type Work } from '@shared/lib/works';
import { SUPPORT_URL } from '../lib/support';
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Pwa from '../components/Pwa.astro';
import CommandPalette from '@shared/components/CommandPalette.svelte';
import { jsonLdSafe } from '../lib/jsonld';
import '@shared/styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Home-page SEO + social card (absolute URLs need Astro.site, set in config).
const homeDescription =
  'Read the complete works of Plato with the original Greek and a facing' +
  ' English translation, side by side — with click-to-parse morphology,' +
  ' dictionary lookup, Stephanus citation, and full-text search across the corpus.';
const canonical = Astro.site ? new URL(`${base}/`, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL(`${base}/og-default.png`, Astro.site).href : undefined;
// Resolve the corpus taxonomy into per-shelf view models. Each shelf holds a
// flat list of cards. A card is an existing work (clickable → its landing
// page) or a "coming soon" placeholder (works not yet added). Each card row
// becomes a single tappable card; the editions/translations live on the
// work's landing page (/<work>).
type Card =
  | { kind: 'work'; work: Work }
  | { kind: 'soon'; title: string };

interface ShelfView {
  numeral: string;
  title: string;
  count: number;   // total cards (works + soon)
  cards: Card[];
}

const toCards = (ws: { id?: string; title?: string }[]): Card[] =>
  ws.flatMap((cw) => {
    const w = cw.id ? getWork(cw.id) : undefined;
    if (w) return [{ kind: 'work', work: w } as Card];
    if (cw.title) return [{ kind: 'soon', title: cw.title } as Card];
    return [];
  });

const shelves: ShelfView[] = SHELVES.map((s) => {
  const cards = toCards(s.works);
  return { numeral: s.numeral, title: s.title, count: cards.length, cards };
});

// "Start here" — a curated featured strip above the shelves (see START_HERE
// in shared/lib/works.ts). These works also keep their normal place in their
// thematic shelf below; this row is an additive pointer for newcomers, not an
// extra division.
const startHere: Work[] = START_HERE.map((id) => getWork(id)).filter((w): w is Work => Boolean(w));

// Structured data: identify the site (WebSite) and enumerate every built work as
// an ItemList of CreativeWorks linking to its landing page. This tells Google the
// home page is the hub for the whole corpus, reinforcing the per-work pages that
// carry the long-tail "<work> greek & english" queries. Absolute URLs need
// Astro.site (set in config); emitted only when present.
const builtWorks = shelves.flatMap((s) =>
  s.cards.filter((c): c is Extract<Card, { kind: 'work' }> => c.kind === 'work'),
);
const structuredData = Astro.site
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'The Plato Reader',
        alternateName: 'Plato in Greek & English',
        url: new URL(`${base}/`, Astro.site).href,
        description: homeDescription,
      },
      {
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        name: 'The Complete Works of Plato',
        numberOfItems: builtWorks.length,
        itemListElement: builtWorks.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.work.title,
          url: new URL(`${base}${workLanding(c.work.id)}/`, Astro.site).href,
        })),
      },
    ]
  : null;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- TODO: register this property in Google Search Console and add its
       verification token here (a sibling reader's token was intentionally
       removed from this file — it belongs to a different GSC property). -->
  <ThemeInit />
  <title>The Plato Reader — Complete Works in Greek &amp; English</title>
  <meta name="description" content={homeDescription} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content="The Plato Reader — Complete Works in Greek & English" />
  <meta property="og:description" content={homeDescription} />
  <meta property="og:site_name" content="The Plato Reader" />
  {canonical && <meta property="og:url" content={canonical} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="The Plato Reader — Complete Works in Greek & English" />
  <meta name="twitter:description" content={homeDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  {structuredData && structuredData.map((sd) => (
    <script type="application/ld+json" set:html={jsonLdSafe(sd)} />
  ))}
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon.png`} type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <Pwa />
</head>
<body class="home">
  <CommandPalette client:load />
  <div class="home-theme"><ThemeToggle /></div>
  <main class="corpus">
    <header class="masthead">
      <p class="eyebrow">Plato</p>
      <h1>The Plato Reader</h1>
      <p class="lede">A parallel-text reader with morphology, dictionary, and Stephanus citation. Choose a dialogue to begin.</p>
      <p class="wip-note">
        <strong>Work in progress.</strong> The translation alignment is still
        being refined. Spotted an error or have a suggestion?
        <button id="feedback-btn-wip" style="background:none;border:none;padding:0;cursor:pointer;font:inherit;color:var(--accent);text-decoration:underline;">Let me know</button>.
      </p>
    </header>

    <a
      class="search-card resume-card"
      id="resume-card"
      href="#"
      hidden
      data-works={JSON.stringify(Object.fromEntries(
        builtWorks.map((c) => [c.work.id, { title: c.work.title, books: c.work.books }]),
      ))}
    >
      <span class="search-card-name">Continue reading</span>
      <span class="search-card-meta" id="resume-meta"></span>
      <span class="chev-right" aria-hidden="true">›</span>
    </a>

    <a class="search-card" href={`${base}/search`}>
      <span class="search-card-name">Search the Corpus</span>
      <span class="search-card-meta">Greek &amp; English · all works</span>
      <span class="chev-right" aria-hidden="true">›</span>
    </a>

    <a class="search-card" href={`${base}/lemma/`}>
      <span class="search-card-name">Greek Lexicon</span>
      <span class="search-card-meta">Key words · frequency &amp; concordance</span>
      <span class="chev-right" aria-hidden="true">›</span>
    </a>

    <section class="support-card">
      <div class="eyebrow">Support <span class="gk">χάρις</span></div>
      <h2>Support the Plato Reader</h2>
      <p>The reader is free and open. A contribution helps defray development costs and keeps it that way.</p>
      <a class="btn-donate" href={SUPPORT_URL} target="_blank" rel="noopener">Make a gift</a>
    </section>

    <hr class="home-rule" />
    <h2 class="works-heading start-here-heading">Start here</h2>
    <div class="works-grid start-here-grid">
      {startHere.map((w) => (
        <a class="work-card work-card-featured" href={`${base}${workLanding(w.id)}`}>
          <span class="work-name">{w.title}</span>
          <span class="work-blurb">{w.blurb}</span>
          <span class="work-meta">{w.abbr} · {w.books} book{w.books > 1 ? 's' : ''}</span>
          {w.authenticity && w.authenticity !== 'genuine' &&
            <span class="status-tag">{AUTHENTICITY_LABEL[w.authenticity]}</span>}
        </a>
      ))}
    </div>

    <h2 class="works-heading">Open a Work</h2>

    <div class="toc">
      {shelves.map((s) => (
        <section class="cat">
          <button class="cat-toggle" type="button" aria-expanded="false">
            <span class="cat-head">
              <span class="cat-num">{s.numeral}.</span> {s.title}
              <span class="cat-count">· {s.count} work{s.count > 1 ? 's' : ''}</span>
            </span>
            <span class="cat-chev" aria-hidden="true"></span>
          </button>
          <div class="cat-body">
            <div class="works-grid">
              {s.cards.map((c) => (
                c.kind === 'work' ? (
                  <a class="work-card" href={`${base}${workLanding(c.work.id)}`}>
                    <span class="work-name">{c.work.title}</span>
                    <span class="work-blurb">{c.work.blurb}</span>
                    <span class="work-meta">{c.work.abbr} · {c.work.books} book{c.work.books > 1 ? 's' : ''}</span>
                    {c.work.authenticity && c.work.authenticity !== 'genuine' &&
                      <span class="status-tag">{AUTHENTICITY_LABEL[c.work.authenticity]}</span>}
                  </a>
                ) : (
                  <div class="work-card soon" aria-disabled="true">
                    <span class="work-name">{c.title}</span>
                    <span class="soon-tag">Coming soon</span>
                  </div>
                )
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <nav class="home-foot">
      <a class="foot-sibling" href="https://johnhboyer-sys.github.io/aristotle-reader/" target="_blank" rel="noopener">Also: The Aristotle Reader ↗</a>
      <span aria-hidden="true">·</span>
      <a href={`${base}/attribution`}>Texts &amp; Licences</a>
      <span aria-hidden="true">·</span>
      <a href={`${base}/support`}>Support</a>
      <span aria-hidden="true">·</span>
      <button id="feedback-btn">Request a Feature / Report an Error</button>
      <span aria-hidden="true">·</span>
      <a href="https://x.com/johnhboyer" target="_blank" rel="noopener">Site by John H. Boyer</a>
    </nav>
  </main>
  <style>
    .wip-note {
      margin: 1rem auto 0;
      max-width: 40rem;
      font-size: 0.85rem;
      line-height: 1.5;
      opacity: 0.8;
      text-wrap: pretty;
    }
    .wip-note a { text-decoration: underline; }
  </style>

  <style>
    body.home { background: var(--page-bg); color: var(--text); }
    .home-theme { position: fixed; top: 1rem; right: 1rem; z-index: 10; }
    .corpus {
      max-width: 56rem;
      margin: 0 auto;
      padding: clamp(2.5rem, 8vh, 6rem) 1.5rem 4rem;
    }
    /* The intro column stays narrow and centred; only the works grid widens. */
    .masthead, .search-card, .support-card {
      max-width: 40rem;
      margin-inline: auto;
    }
    .masthead { text-align: center; margin-bottom: 2.75rem; }
    .eyebrow {
      font-family: var(--font-ui);
      text-transform: uppercase;
      letter-spacing: .28em;
      font-size: .72rem;
      color: var(--accent-light);
      margin-bottom: .6rem;
    }
    .masthead h1 {
      font-family: var(--font-greek);
      font-weight: 400;
      font-size: clamp(2.1rem, 6vw, 2.9rem);
      letter-spacing: .01em;
      color: var(--text);
      text-wrap: balance;
    }
    .lede {
      font-family: var(--font-english);
      color: var(--text-mid);
      font-size: 1.02rem;
      max-width: 28rem;
      margin: .9rem auto 0;
      line-height: 1.5;
      text-wrap: pretty;
    }

    .search-card {
      display: flex;
      align-items: baseline;
      gap: .75rem;
      background: var(--col-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.05rem 1.3rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color .15s ease, box-shadow .15s ease;
    }
    .search-card:hover { border-color: var(--accent-light); box-shadow: 0 6px 22px rgba(0,0,0,.05); }
    .search-card-name {
      font-family: var(--font-english);
      font-weight: 600;
      font-size: 1.2rem;
      color: var(--accent);
    }
    .search-card-meta {
      font-family: var(--font-ui);
      font-size: .76rem;
      letter-spacing: .04em;
      color: var(--text-light);
      text-transform: uppercase;
    }
    .search-card .chev-right {
      margin-left: auto;
      align-self: center;
      color: var(--text-light);
      font-size: 1.5rem;
      line-height: 1;
    }
    .search-card:hover .chev-right { color: var(--accent-light); }

    /* Continue-reading card: same idiom as .search-card, tinted so returning
       readers spot it first. Hidden until the script finds a saved position. */
    .resume-card { border-color: var(--accent-light); margin-bottom: .55rem; }
    .resume-card[hidden] { display: none; }
    .search-card + .search-card { margin-top: .55rem; }

    /* Support / donation card — sits below the search card, above the works
       list. Same panel idiom as .search-card (col-bg, border, 8px radius), but
       with a heading + body + filled CTA rather than a single row. */
    /* .support-card / .btn-donate styles now live in global.css (shared with
       the work landing pages). */

    .home-rule {
      border: none;
      border-top: 1px solid var(--border);
      margin: 1.6rem 0 1.3rem;
    }
    .works-heading {
      font-family: var(--font-ui);
      font-size: .78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--text-light);
      margin-bottom: 1rem;
    }

    .toc { display: flex; flex-direction: column; }

    /* ── Division (category) ─────────────────────────────────────────────── */
    .cat-toggle {
      width: 100%;
      background: none;
      border: none;
      padding: 0;
      margin: 1.9rem 0 .85rem;
      display: flex;
      align-items: baseline;
      gap: .55rem;
      text-align: left;
      color: inherit;
      font: inherit;
      border-bottom: 1px solid var(--border);
      padding-bottom: .35rem;
    }
    .toc > .cat:first-child .cat-toggle { margin-top: 0; }
    .cat-head {
      font-family: var(--font-greek);
      font-weight: 400;
      font-size: 1.5rem;
      color: var(--text);
      flex: 1;
    }
    .cat-num {
      font-family: var(--font-ui);
      font-size: .95rem;
      font-weight: 600;
      letter-spacing: .04em;
      color: var(--accent-light);
    }
    .cat-count {
      font-family: var(--font-ui);
      font-size: .72rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--text-light);
    }
    /* Chevron shown only on mobile (where the header is a real toggle). */
    .cat-chev {
      align-self: center;
      flex-shrink: 0;
      width: .5rem; height: .5rem;
      border-right: 1.5px solid var(--text-light);
      border-bottom: 1.5px solid var(--text-light);
      transform: rotate(45deg) translateY(-2px);
      transition: transform .18s ease;
    }
    .cat[data-open] .cat-chev { transform: rotate(225deg); }

    /* ── "Start here" featured strip ─────────────────────────────────────── */
    .start-here-heading { margin-top: 0; }
    .start-here-grid {
      grid-template-columns: repeat(auto-fill, minmax(16.5rem, 1fr));
      margin-bottom: 1.9rem;
    }
    /* Compound selector (.work-card.work-card-featured) so these win over the
       plain .work-card rules below regardless of source order. */
    .work-card.work-card-featured {
      border-color: var(--accent-light);
      padding: 1.15rem 1.35rem;
    }
    .work-card.work-card-featured .work-name { font-size: 1.45rem; }
    .work-card.work-card-featured:hover { box-shadow: 0 8px 26px rgba(0,0,0,.07); }

    /* ── Work cards ──────────────────────────────────────────────────────── */
    .works-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
      gap: .55rem;
      margin-bottom: .55rem;
    }
    .work-card {
      display: flex;
      flex-direction: column;
      gap: .18rem;
      background: var(--col-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: .9rem 1.1rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color .15s ease, box-shadow .15s ease;
    }
    .work-card:not(.soon):hover {
      border-color: var(--accent-light);
      box-shadow: 0 6px 22px rgba(0,0,0,.05);
    }
    .work-name {
      font-family: var(--font-greek);
      font-size: 1.3rem;
      color: var(--text);
      line-height: 1.25;
    }
    .work-blurb {
      font-family: var(--font-english);
      font-size: .8rem;
      color: var(--text-light);
      line-height: 1.4;
      text-wrap: pretty;
    }
    .work-meta {
      font-family: var(--font-ui);
      font-size: .72rem;
      letter-spacing: .04em;
      color: var(--text-light);
      text-transform: uppercase;
      white-space: nowrap;
      margin-top: .1rem;
    }

    /* Not-yet-added works: a quiet, non-interactive placeholder. */
    .work-card.soon {
      background: transparent;
      border-style: dashed;
      cursor: default;
      flex-direction: row;
      align-items: baseline;
      gap: .75rem;
    }
    .work-card.soon .work-name {
      font-size: 1.15rem;
      color: var(--text-light);
    }
    .work-card.soon .soon-tag {
      margin-left: auto;
      align-self: center;
      font-family: var(--font-ui);
      font-size: .66rem;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--text-light);
      opacity: .8;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: .12rem .5rem;
      white-space: nowrap;
    }

    /* ── Mobile-only collapse ────────────────────────────────────────────── */
    /* Base (mobile-first): shelves collapse; tapping a header opens its body. */
    .cat:not([data-open]) .cat-body { display: none; }
    .cat-toggle { cursor: pointer; }

    /* Desktop: everything expanded, headers are static (no toggle / chevron). */
    @media (min-width: 48rem) {
      .cat-body { display: block !important; }
      .cat-toggle { pointer-events: none; cursor: default; }
      .cat-chev, .cat-count { display: none; }
    }

    .home-foot {
      margin-top: 2.5rem;
      text-align: center;
      font-family: var(--font-ui);
      font-size: .85rem;
      color: var(--text-light);
      display: flex; justify-content: center; flex-wrap: wrap; gap: .5rem .7rem;
    }
    .home-foot a { color: var(--text-mid); text-decoration: none; }
    .home-foot a:hover { color: var(--accent); }
    /* The companion reader — a "see also" pointer, gently emphasised. */
    .home-foot a.foot-sibling { color: var(--accent); font-weight: 600; }
    .home-foot button {
      background: none; border: none; padding: 0; cursor: pointer;
      font: inherit; font-size: .85rem; color: var(--text-mid);
    }
    .home-foot button:hover { color: var(--accent); }

    /* Feedback modal */
    #feedback-modal {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,.45); align-items: center; justify-content: center;
    }
    #feedback-modal.open { display: flex; }
    .fb-box {
      background: var(--page-bg); border: 1px solid var(--rule);
      border-radius: 8px; padding: 1.75rem 2rem; width: min(440px, 90vw);
      font-family: var(--font-ui); box-shadow: 0 8px 32px rgba(0,0,0,.18);
    }
    .fb-box h2 {
      margin: 0 0 1.1rem; font-size: 1rem; font-weight: 600; color: var(--text);
    }
    .fb-type { display: flex; gap: 1.25rem; margin-bottom: 1rem; }
    .fb-type label { display: flex; align-items: center; gap: .4rem; cursor: pointer;
      font-size: .875rem; color: var(--text); }
    .fb-box textarea {
      width: 100%; box-sizing: border-box; min-height: 110px; resize: vertical;
      border: 1px solid var(--rule); border-radius: 4px; padding: .6rem .75rem;
      font-family: var(--font-ui); font-size: .875rem;
      background: var(--page-bg); color: var(--text);
    }
    .fb-box textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
    .fb-actions { display: flex; justify-content: flex-end; gap: .6rem; margin-top: .9rem; }
    .fb-cancel {
      background: none; border: 1px solid var(--rule); border-radius: 4px;
      padding: .4rem .9rem; cursor: pointer; font: inherit; font-size: .85rem;
      color: var(--text-mid);
    }
    .fb-cancel:hover { border-color: var(--text-mid); }
    .fb-submit {
      background: var(--accent); color: #fff; border: none; border-radius: 4px;
      padding: .4rem 1rem; cursor: pointer; font: inherit; font-size: .85rem;
      font-weight: 600;
    }
    .fb-submit:hover { opacity: .88; }
    .fb-submit:disabled { opacity: .45; cursor: default; }
  </style>

  <!-- Feedback modal -->
  <div id="feedback-modal" role="dialog" aria-modal="true" aria-labelledby="fb-title" tabindex="-1">
    <div class="fb-box">
      <h2 id="fb-title">Request a Feature / Report an Error</h2>
      <div class="fb-type">
        <label><input type="radio" name="fb-type" value="feature" checked /> Feature request</label>
        <label><input type="radio" name="fb-type" value="bug" /> Bug / error report</label>
      </div>
      <textarea id="fb-message" placeholder="Describe the feature or error…"></textarea>
      <div class="fb-actions">
        <button class="fb-cancel" id="fb-cancel">Cancel</button>
        <button class="fb-submit" id="fb-submit">Send</button>
      </div>
    </div>
  </div>

  <script>
    const modal = document.getElementById('feedback-modal')!;
    const openBtn = document.getElementById('feedback-btn')!;
    const cancelBtn = document.getElementById('fb-cancel')!;
    const submitBtn = document.getElementById('fb-submit')!;
    const textarea = document.getElementById('fb-message') as HTMLTextAreaElement;
    let feedbackTrigger: HTMLElement | null = null;

    const open = (e?: Event) => {
      feedbackTrigger = e?.currentTarget instanceof HTMLElement ? e.currentTarget : null;
      modal.classList.add('open');
      textarea.value = '';
      textarea.focus();
    };
    const close = () => {
      modal.classList.remove('open');
      feedbackTrigger?.focus();
      feedbackTrigger = null;
    };

    openBtn.addEventListener('click', open);
    document.getElementById('feedback-btn-wip')?.addEventListener('click', open);
    cancelBtn.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => {
      if (!modal.classList.contains('open')) return;
      if (e.key === 'Escape') {
        close();
        return;
      }
      if (e.key !== 'Tab') return;
      const els = Array.from(modal.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])',
      )).filter((el) => !el.hasAttribute('disabled') && el.tabIndex !== -1);
      if (els.length === 0) {
        e.preventDefault();
        modal.focus();
        return;
      }
      const first = els[0];
      const last = els[els.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    submitBtn.addEventListener('click', () => {
      const msg = textarea.value.trim();
      if (!msg) return;
      const type = (document.querySelector('input[name="fb-type"]:checked') as HTMLInputElement).value;
      const subject = type === 'feature'
        ? 'Plato Reader: Feature Request'
        : 'Plato Reader: Bug Report';
      window.location.href =
        `mailto:jhboyer@loyno.edu?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(msg)}`;
      close();
    });
  </script>

  <script>
    // "Continue reading" card: shown only when the reader has saved a recent
    // position (localStorage — see shared/lib/resume.ts), pointing back into
    // the reader at the remembered book + Bekker citation.
    import { lastRead } from '@shared/lib/resume';

    const card = document.getElementById('resume-card') as HTMLAnchorElement | null;
    if (card) {
      const works: Record<string, { title: string; books: number }> =
        JSON.parse(card.dataset.works || '{}');
      const last = lastRead((w) => w in works);
      if (last) {
        const w = works[last.work];
        const book = Math.min(Math.max(1, last.book), w.books);
        const bookBit = w.books > 1 ? ` · Book ${book}` : '';
        const citeBit = last.cite ? ` · ${last.cite}` : '';
        card.querySelector('#resume-meta')!.textContent = `${w.title}${bookBit}${citeBit}`;
        const base = (import.meta.env.BASE_URL as string).replace(/\/$/, '');
        card.href = `${base}/${last.work}/book/${book}${last.cite ? `#${last.cite}` : ''}`;
        card.hidden = false;
      }
    }
  </script>

  <script>
    // Mobile-only collapse: tapping a shelf header toggles its body. On
    // desktop the buttons are pointer-events:none (see CSS), so these never
    // fire.
    const toggles: [string, string][] = [['.cat-toggle', '.cat']];
    for (const [btnSel, boxSel] of toggles) {
      for (const btn of document.querySelectorAll<HTMLButtonElement>(btnSel)) {
        btn.addEventListener('click', () => {
          const open = btn.closest(boxSel)!.toggleAttribute('data-open');
          btn.setAttribute('aria-expanded', String(open));
        });
      }
    }
  </script>
</body>
</html>
