---
import Search from '@shared/components/Search.svelte';
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Pwa from '../components/Pwa.astro';
import { jsonLdSafe } from '../lib/jsonld';
import '@shared/styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const searchDescription =
  'Search the dialogues of Plato across the original Greek and English' +
  ' translation — by word or phrase, in Greek script or Beta Code, with results' +
  ' cited by Stephanus page.';
const canonical = Astro.site ? new URL(`${base}/search/`, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL(`${base}/og-default.png`, Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Search Plato in Greek and English',
  description: searchDescription,
  ...(canonical ? { url: canonical } : {}),
  isPartOf: { '@type': 'WebSite', name: 'The Plato Reader' },
  potentialAction: {
    '@type': 'SearchAction',
    target: canonical ? `${canonical}?q={search_term_string}` : undefined,
    'query-input': 'required name=search_term_string',
  },
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeInit />
  <title>Search Plato in Greek and English</title>
  <meta name="description" content={searchDescription} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Search Plato in Greek and English" />
  <meta property="og:description" content={searchDescription} />
  <meta property="og:site_name" content="The Plato Reader" />
  {canonical && <meta property="og:url" content={canonical} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Search Plato in Greek and English" />
  <meta name="twitter:description" content={searchDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <script type="application/ld+json" set:html={jsonLdSafe(jsonLd)} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon.png`} type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <Pwa />
</head>
<body>
  <header class="simple-header">
    <div class="header-title">
      <a class="home-link" href={`${base}/`}>Home</a>
      <span class="title-sep">›</span>
      <span class="header-static">Search</span>
    </div>
    <nav class="header-actions" aria-label="Navigation">
      <a href={`${base}/`} class="search-link">All works</a>
      <a href={`${base}/lemma/`} class="search-link">Lexicon</a>
      <ThemeToggle />
    </nav>
  </header>
  <Search client:load />
</body>
</html>
