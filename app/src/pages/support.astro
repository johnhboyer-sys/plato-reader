---
// A shareable on-site support/donation page. Giving itself goes through the
// Stripe Payment Link (SUPPORT_URL); this page gives that appeal a real URL on
// our own domain with a branded Open Graph card (public/og-support.png).
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { SUPPORT_URL } from '../lib/support';
import { jsonLdSafe } from '../lib/jsonld';
import '@shared/styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pageTitle = 'Support the Plato Reader';
const metaDescription =
  'Help keep the Plato Reader free and open — an ad-free parallel ' +
  'Greek–English edition of Aristotle’s complete works, with click-to-parse ' +
  'morphology, dictionary entries, and exact Bekker citation.';
const canonical = Astro.site
  ? new URL(`${base}/support/`, Astro.site).href : undefined;
const ogImage = Astro.site
  ? new URL(`${base}/og-support.png`, Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: metaDescription,
  ...(canonical ? { url: canonical } : {}),
  isPartOf: { '@type': 'WebSite', name: 'The Plato Reader' },
  potentialAction: {
    '@type': 'DonateAction',
    target: SUPPORT_URL,
  },
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeInit />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={metaDescription} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:site_name" content="The Plato Reader" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={metaDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <script type="application/ld+json" set:html={jsonLdSafe(jsonLd)} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon.png`} type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    .sp-body { max-width: 600px; margin: 0 auto; padding: 3rem 1rem 5rem; font-family: var(--font-english); color: var(--text); }
    .sp-eyebrow {
      font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600;
      letter-spacing: .12em; text-transform: uppercase; color: var(--text-light);
      display: flex; align-items: baseline; gap: 0.55rem; margin: 0 0 0.5rem;
    }
    .sp-eyebrow .gk { font-family: var(--font-greek); font-size: 1.05rem; font-weight: 400; letter-spacing: 0; text-transform: none; color: var(--accent-light); }
    .sp-body h1 { font-family: var(--font-english); font-weight: 600; font-size: 2rem; line-height: 1.15; margin: 0 0 1rem; }
    .sp-lede { font-size: 1.12rem; line-height: 1.6; margin: 0 0 1.1rem; }
    .sp-body p { font-size: 1rem; line-height: 1.7; color: var(--text-mid); margin: 0 0 1.1rem; }
    .sp-cta { margin: 1.6rem 0 1.2rem; }
    .sp-list { list-style: none; padding: 0; margin: 0 0 1.6rem; display: grid; gap: 0.55rem; }
    .sp-list li { font-size: 0.97rem; line-height: 1.55; color: var(--text-mid); padding-left: 1.4rem; position: relative; }
    .sp-list li::before { content: "χ"; font-family: var(--font-greek); color: var(--accent-light); position: absolute; left: 0; top: 0; }
    .sp-note { font-size: 0.85rem; color: var(--text-light); }
    .sp-note a { color: var(--accent); }
  </style>
</head>
<body>
  <header class="simple-header">
    <div class="header-title">
      <a class="home-link" href={`${base}/`}>Aristotle</a>
      <span class="title-sep">›</span>
      <span class="header-static">Support</span>
    </div>
    <nav class="header-actions" aria-label="Navigation">
      <a href={`${base}/`} class="search-link">All works</a>
      <a href={`${base}/search`} class="search-link">Search</a>
      <ThemeToggle />
    </nav>
  </header>

  <main class="sp-body">
    <p class="sp-eyebrow">Support <span class="gk">χάρις</span></p>
    <h1>Support the Plato Reader</h1>
    <p class="sp-lede">
      The Plato Reader is an ad-free parallel Greek–English edition of
      Aristotle’s complete works — with click-to-parse morphology, dictionary
      entries, and exact Bekker citation. It is free to read and always will be.
    </p>
    <p>
      It is built and maintained by one person, and runs on no advertising and no
      paywall. A contribution helps defray development costs and keeps the reader
      free and open for students, teachers, and readers everywhere.
    </p>
    <ul class="sp-list">
      <li>Hosting and the tools that keep the site fast and ad-free.</li>
      <li>Aligning more public-domain translations to the Greek, line by line.</li>
      <li>Adding works, glossaries, and reading aids across the corpus.</li>
    </ul>
    <div class="sp-cta">
      <a class="btn-donate" href={SUPPORT_URL} target="_blank" rel="noopener">Make a gift</a>
    </div>
    <p class="sp-note">
      Gifts are processed securely by Stripe — you choose the amount. Thank you
      for keeping the reader free. <span class="gk" style="font-family:var(--font-greek);color:var(--accent-light);">χάρις</span>.
    </p>
  </main>
</body>
</html>
