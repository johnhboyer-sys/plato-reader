---
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { jsonLdSafe } from '../lib/jsonld';
import '@shared/styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pageTitle = 'Page Not Found — Plato Reader';
const metaDescription =
  "The requested Plato Reader page could not be found. Return to the corpus or search Aristotle's Greek and English texts.";
const canonical = Astro.site ? new URL(`${base}/404/`, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL(`${base}/og-default.png`, Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: metaDescription,
  ...(canonical ? { url: canonical } : {}),
  isPartOf: { '@type': 'WebSite', name: 'The Plato Reader' },
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeInit />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  <meta name="robots" content="noindex,follow" />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:site_name" content="The Plato Reader" />
  {canonical && <meta property="og:url" content={canonical} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={metaDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <script type="application/ld+json" set:html={jsonLdSafe(jsonLd)} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="theme-corner"><ThemeToggle /></div>
  <main class="not-found">
    <p class="eyebrow">Aristotle</p>
    <figure class="goatstag">
      <svg viewBox="0 0 220 200" role="img" aria-labelledby="gs-title"
           fill="none" stroke="currentColor" stroke-width="2.4"
           stroke-linecap="round" stroke-linejoin="round">
        <title id="gs-title">A goat-stag (tragelaphos): an antlered, bearded creature</title>
        <!-- lean body + long goat head -->
        <path d="M16,78 C14,72 18,67 26,65 C33,63 40,62 47,59 C51,57 54,55 56,50
                 C60,53 62,57 63,62 C70,61 78,60 86,61 C112,57 148,57 176,68
                 C182,64 187,62 190,66 C189,71 185,74 180,76 C178,84 175,92 172,100
                 C150,106 120,108 100,106 C92,105 84,104 78,102 C74,101 70,99 67,96
                 C64,92 62,88 60,84 C57,86 54,86 50,86 C46,87 43,89 41,90
                 C33,90 24,87 19,83 C17,82 16,80 16,78 Z"/>
        <!-- snout: mouth line -->
        <path d="M18,80 C21,82 24,83 27,82"/>
        <!-- goat ear -->
        <path d="M62,57 C69,51 76,50 81,53 C77,59 69,62 64,61 C63,60 62,58 62,57 Z"/>
        <!-- stag antlers (large, branching) -->
        <path d="M54,50 C50,38 47,28 44,14"/>
        <path d="M49,34 C42,31 37,28 31,22"/>
        <path d="M47,26 C41,23 37,19 33,12"/>
        <path d="M45,18 C42,13 40,9 39,5"/>
        <path d="M57,49 C61,37 64,27 67,13"/>
        <path d="M62,33 C68,30 73,27 79,21"/>
        <path d="M64,25 C70,22 75,18 79,11"/>
        <path d="M66,17 C69,12 71,8 72,4"/>
        <!-- full goat beard -->
        <path d="M42,88 C39,98 39,108 42,120"/>
        <path d="M47,89 C45,99 45,109 48,121"/>
        <path d="M52,89 C50,98 50,107 52,117"/>
        <!-- long lean legs -->
        <path d="M82,104 L80,172"/>
        <path d="M94,105 L96,174"/>
        <path d="M156,102 L158,172"/>
        <path d="M168,100 L170,174"/>
        <!-- hooves -->
        <path d="M76,172 L84,172"/>
        <path d="M92,174 L100,174"/>
        <path d="M152,172 L160,172"/>
        <path d="M164,174 L172,174"/>
        <!-- eye -->
        <circle cx="38" cy="72" r="1.8" fill="currentColor" stroke="none"/>
      </svg>
      <figcaption><span lang="grc">τραγέλαφος</span> · the goat-stag</figcaption>
    </figure>
    <h1>Page not found</h1>
    <p class="lede">The <em>goat-stag</em> is Aristotle's example of a name that
      signifies something which does not exist (<em>De Interpretatione</em> 16a16).
      So, it would seem, is the page you're looking for.</p>
    <div class="actions">
      <a class="btn-primary" href={`${base}/`}>Back to the corpus</a>
      <a class="btn-secondary" href={`${base}/search`}>Search</a>
    </div>
  </main>

  <style>
    body { background: var(--page-bg); color: var(--text); margin: 0; }
    .theme-corner { position: fixed; top: 1rem; right: 1rem; z-index: 10; }
    .not-found {
      max-width: 36rem;
      margin: 0 auto;
      padding: clamp(4rem, 14vh, 9rem) 1.5rem 4rem;
      text-align: center;
    }
    .eyebrow {
      font-family: var(--font-ui);
      text-transform: uppercase;
      letter-spacing: .28em;
      font-size: .72rem;
      color: var(--accent-light);
      margin: 0 0 .6rem;
    }
    h1 {
      font-family: var(--font-greek);
      font-weight: 400;
      font-size: clamp(2rem, 5vw, 2.6rem);
      color: var(--text);
      margin: 0 0 1rem;
    }
    .lede {
      font-family: var(--font-english);
      color: var(--text-mid);
      font-size: 1rem;
      line-height: 1.55;
      margin: 0 0 2rem;
    }
    .goatstag { margin: 0 0 1.4rem; color: var(--accent); }
    .goatstag svg { width: clamp(150px, 30vw, 210px); height: auto; opacity: .92; }
    .goatstag figcaption {
      font-family: var(--font-greek);
      font-size: .95rem;
      color: var(--text-mid);
      margin-top: .5rem;
    }
    .actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      font-family: var(--font-ui);
      font-size: .9rem;
      font-weight: 600;
      padding: .55rem 1.25rem;
      border-radius: 6px;
      transition: opacity .15s ease;
    }
    .btn-primary:hover { opacity: .86; }
    .btn-secondary {
      background: var(--col-bg);
      color: var(--text-mid);
      text-decoration: none;
      font-family: var(--font-ui);
      font-size: .9rem;
      padding: .55rem 1.25rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      transition: border-color .15s ease;
    }
    .btn-secondary:hover { border-color: var(--accent-light); color: var(--accent); }
  </style>
</body>
</html>
