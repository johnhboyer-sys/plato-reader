---
import ThemeInit from '../components/ThemeInit.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Pwa from '../components/Pwa.astro';
import { jsonLdSafe } from '../lib/jsonld';
import '@shared/styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pageTitle = 'Page Not Found — Plato Reader';
const metaDescription =
  "The requested Plato Reader page could not be found. Return to the corpus or search Plato's Greek and English texts.";
const canonical = Astro.site ? new URL(`${base}/404/`, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL(`${base}/og-default.png`, Astro.site).href : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: metaDescription,
  ...(canonical ? { url: canonical } : {}),
  isPartOf: { '@type': 'WebSite', name: 'The Plato Reader' },
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeInit />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  <meta name="robots" content="noindex,follow" />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:site_name" content="The Plato Reader" />
  {canonical && <meta property="og:url" content={canonical} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={metaDescription} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <script type="application/ld+json" set:html={jsonLdSafe(jsonLd)} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon.png`} type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <Pwa />
</head>
<body>
  <div class="theme-corner"><ThemeToggle /></div>
  <main class="not-found">
    <p class="eyebrow">Plato</p>
    <figure class="goatstag">
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="meno-title"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <title id="meno-title">The doubled square from the Meno's geometry lesson</title>
        <rect x="20" y="20" width="160" height="160"/>
        <path d="M100,20 L100,180" stroke-dasharray="4 5" opacity=".55"/>
        <path d="M20,100 L180,100" stroke-dasharray="4 5" opacity=".55"/>
        <!-- the square on the diagonal — the slave boy's doubled square -->
        <path d="M100,20 L180,100 L100,180 L20,100 Z" stroke-width="2.8"/>
        <circle cx="100" cy="20" r="2.4" fill="currentColor" stroke="none"/>
        <circle cx="180" cy="100" r="2.4" fill="currentColor" stroke="none"/>
        <circle cx="100" cy="180" r="2.4" fill="currentColor" stroke="none"/>
        <circle cx="20" cy="100" r="2.4" fill="currentColor" stroke="none"/>
      </svg>
      <figcaption><span lang="grc">ἀνάμνησις</span> · recollection (<em>Meno</em> 82b–85b)</figcaption>
    </figure>
    <h1>Page not found</h1>
    <p class="lede">&ldquo;And how will you search for a page, Socrates, when you
      do not know at all what it is? Even if you should stumble upon it, how will
      you know it is the page, if you did not know it to begin with?&rdquo;
      &mdash; <em>Meno</em> 80d, more or less</p>
    <p class="lede">Try recollecting &mdash; you may have known this URL in a former life.</p>
    <div class="actions">
      <a class="btn-primary" href={`${base}/`}>Back to the corpus</a>
      <a class="btn-secondary" href={`${base}/search`}>Search</a>
    </div>
  </main>

  <style>
    body { background: var(--page-bg); color: var(--text); margin: 0; }
    .theme-corner { position: fixed; top: 1rem; right: 1rem; z-index: 10; }
    .not-found {
      max-width: 36rem;
      margin: 0 auto;
      padding: clamp(4rem, 14vh, 9rem) 1.5rem 4rem;
      text-align: center;
    }
    .eyebrow {
      font-family: var(--font-ui);
      text-transform: uppercase;
      letter-spacing: .28em;
      font-size: .72rem;
      color: var(--accent-light);
      margin: 0 0 .6rem;
    }
    h1 {
      font-family: var(--font-greek);
      font-weight: 400;
      font-size: clamp(2rem, 5vw, 2.6rem);
      color: var(--text);
      margin: 0 0 1rem;
    }
    .lede {
      font-family: var(--font-english);
      color: var(--text-mid);
      font-size: 1rem;
      line-height: 1.55;
      margin: 0 0 2rem;
    }
    .goatstag { margin: 0 0 1.4rem; color: var(--accent); }
    .goatstag svg { width: clamp(150px, 30vw, 210px); height: auto; opacity: .92; }
    .goatstag figcaption {
      font-family: var(--font-greek);
      font-size: .95rem;
      color: var(--text-mid);
      margin-top: .5rem;
    }
    .actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      font-family: var(--font-ui);
      font-size: .9rem;
      font-weight: 600;
      padding: .55rem 1.25rem;
      border-radius: 6px;
      transition: opacity .15s ease;
    }
    .btn-primary:hover { opacity: .86; }
    .btn-secondary {
      background: var(--col-bg);
      color: var(--text-mid);
      text-decoration: none;
      font-family: var(--font-ui);
      font-size: .9rem;
      padding: .55rem 1.25rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      transition: border-color .15s ease;
    }
    .btn-secondary:hover { border-color: var(--accent-light); color: var(--accent); }
  </style>
</body>
</html>
