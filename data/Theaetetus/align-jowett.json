  {
   "ref_index": 965,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Certainly I accept it.",
   "new": "Precisely."
  },
  {
   "ref_index": 967,
   "speaker": "Theaetetus",
   "score": 0.0842,
   "ref": "Not at all, by Zeus.",
   "new": "Assuredly not."
  },
  {
   "ref_index": 969,
   "speaker": "Theaetetus",
   "score": 0.1065,
   "ref": "Do you mean when we thought that sometimes one letter and sometimes another belonged to th",
   "new": "You mean that I mistook the letters and misspelt the syllables?"
