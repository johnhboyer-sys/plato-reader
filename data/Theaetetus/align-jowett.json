  {
   "ref_index": 794,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "I will agree.",
   "new": "Yes."
  },
  {
   "ref_index": 798,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "How so?",
   "new": "What do you mean?"
