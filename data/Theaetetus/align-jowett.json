  {
   "ref_index": 837,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Precisely.",
   "new": "Exactly."
  },
  {
   "ref_index": 843,
   "speaker": "Theaetetus",
   "score": 0.1004,
   "ref": "Is that not right?",
   "new": "And was that wrong?"
