  {
   "ref_index": 947,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Certainly.",
   "new": "Exactly."
  },
  {
   "ref_index": 953,
   "speaker": "Theaetetus",
   "score": 0.0714,
   "ref": "Yes, I do. At any rate, we say that he who does that speaks or explains.",
   "new": "Certainly; he who so manifests his thought, is said to explain himself."
