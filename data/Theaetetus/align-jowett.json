   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Evidently.",
   "new": "Clearly."
  },
  {
   "ref_index": 983,
   "speaker": "Theaetetus",
   "score": 0.0944,
   "ref": "There is not much doubt about it.",
   "new": "It would seem so."
