  {
   "ref_index": 806,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Of course.",
   "new": "Certainly."
  },
  {
   "ref_index": 808,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Evidently.",
   "new": "Clearly."
  },
  {
   "ref_index": 814,
   "speaker": "Theaetetus",
   "score": 0.0938,
   "ref": "Not by any means, unless, that is, you give it up.",
   "new": "Certainly, I shall not lose heart, if you do not."
