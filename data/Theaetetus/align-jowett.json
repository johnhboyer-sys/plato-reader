  {
   "ref_index": 782,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "We shall.",
   "new": "Very true."
  },
  {
   "ref_index": 790,
   "speaker": "Theaetetus",
   "score": 0.0425,
   "ref": "But that too is absurd.",
   "new": "That, again, would be an absurdity."
  },
  {
   "ref_index": 792,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "Yes, that is reasonable.",
   "new": "A very rational explanation."
