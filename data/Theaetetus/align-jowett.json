  {
   "ref_index": 970,
   "speaker": "Socrates",
   "score": 0.0,
   "ref": "That is what I mean.",
   "new": "Yes."
  },
  {
   "ref_index": 975,
   "speaker": "Theaetetus",
   "score": 0.0,
   "ref": "No, nothing.",
   "new": "He may."
